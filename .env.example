# ---------------------------------------------------------------------------
# Configuracion de Supabase
# ---------------------------------------------------------------------------
# Copia este archivo a ".env" y rellena los valores con los de tu proyecto.
# Los encuentras en: Supabase -> Project Settings -> API
#
#   VITE_SUPABASE_URL          -> "Project URL"
#   VITE_SUPABASE_ANON_KEY     -> "anon public" / "publishable key"
#
# IMPORTANTE: el archivo .env NO se sube a git (esta en .gitignore).
# Estas dos claves son publicas y seguras de usar en el navegador siempre que
# tengas las politicas RLS activadas (este proyecto las trae configuradas).
# ---------------------------------------------------------------------------

VITE_SUPABASE_URL=https://TU-PROYECTO.supabase.co
VITE_SUPABASE_ANON_KEY=TU_CLAVE_ANON_PUBLICA
